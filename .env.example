# Local development override (optional; NODE_ENV=development already uses local defaults)
# NEXT_PUBLIC_DEV=1

# Full in-browser test mode: no API, no DB, no Polar — mock Pro, credits, and data (set to 1)
# NEXT_PUBLIC_TEST_MODE=1

# "Try demo" (marketing) runs entirely in the browser: fresh sample data, no API. Shown in production by default; set
# this to hide the Try demo entry points:
# NEXT_PUBLIC_DISABLE_TRY_DEMO=1

# Legacy note: `DEV=1` is still supported for compatibility, but prefer `NEXT_PUBLIC_DEV`.

# Backend API (defaults: http://127.0.0.1:8080 in DEV, https://api.maskedcarrotlabs.com in prod)
# Use the same base URL in the browser. Full route list: <same base>/docs (FastAPI Swagger).
# Regenerate TypeScript from OpenAPI: start API on :8080, then: npm run api:types
# (edit package.json command if you use a different port / OPENAPI file).
# NEXT_PUBLIC_API_URL=

# Public site origin (defaults: http://127.0.0.1:3001 in DEV, https://goodword.maskedcarrotlabs.com in prod)
# NEXT_PUBLIC_SITE_URL=

# Google OAuth Web client id for GoodWord (must match GOODWORD_GOOGLE_CLIENT_ID on the API)
# NEXT_PUBLIC_GOOGLE_CLIENT_ID=
